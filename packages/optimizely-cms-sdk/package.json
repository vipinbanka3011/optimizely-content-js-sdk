{
  "name": "@optimizely/cms-sdk",
  "version": "2.1.0-beta.0",
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "description": "JavaScript tools for integration with Optimizely CMS",
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.js",
  "exports": {
    ".": {
      "types": "./dist/cjs/index.d.ts",
      "import": "./dist/esm/index.js",
      "require": "./dist/cjs/index.js"
    },
    "./react/server": {
      "types": "./dist/cjs/react/server.d.ts",
      "import": "./dist/esm/react/server.js",
      "require": "./dist/cjs/react/server.js"
    },
    "./react/client": {
      "types": "./dist/cjs/react/client.d.ts",
      "import": "./dist/esm/react/client.js",
      "require": "./dist/cjs/react/client.js"
    },
    "./react/nextjs": {
      "types": "./dist/cjs/react/nextjs.d.ts",
      "import": "./dist/esm/react/nextjs.js",
      "require": "./dist/cjs/react/nextjs.js"
    },
    "./react/richText": {
      "types": "./dist/cjs/react/richText/index.d.ts",
      "import": "./dist/esm/react/richText/index.js",
      "require": "./dist/cjs/react/richText/index.js"
    },
    "./buildConfig": {
      "types": "./dist/cjs/model/buildConfig.d.ts",
      "import": "./dist/esm/model/buildConfig.js"
    },
    "./next": {
      "types": "./dist/cjs/next/metadata.d.ts",
      "import": "./dist/esm/next/metadata.js",
      "require": "./dist/cjs/next/metadata.js"
    },
    "./telemetry": {
      "types": "./dist/cjs/telemetry/index.d.ts",
      "import": "./dist/esm/telemetry/index.js",
      "require": "./dist/cjs/telemetry/index.js"
    }
  },
  "repository": {
    "url": "https://github.com/episerver/content-js-sdk.git"
  },
  "scripts": {
    "prebuild": "node scripts/prebuild.js",
    "build": "tsc --project tsconfig.cjs.json && tsc --project tsconfig.esm.json",
    "clean": "rimraf dist",
    "test": "vitest --typecheck"
  },
  "files": [
    "dist"
  ],
  "keywords": [],
  "author": "",
  "license": "Apache-2.0",
  "packageManager": "pnpm@10.7.0",
  "peerDependencies": {
    "next": ">=14.0.0",
    "react": ">=19.0.0"
  },
  "peerDependenciesMeta": {
    "next": {
      "optional": true
    },
    "react": {
      "optional": true
    }
  },
  "dependencies": {
    "@opentelemetry/api": "^1.9.0"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.0",
    "@types/node": "^22.13.14",
    "@types/react": "^19",
    "jsdom": "^27.0.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "rimraf": "^6.0.1",
    "typescript": "^5.8.2",
    "vitest": "^3.2.6"
  }
}
